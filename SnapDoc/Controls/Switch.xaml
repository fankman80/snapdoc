<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    xmlns="http://schemas.microsoft.com/dotnet/maui/global"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:SnapDoc.Controls"    
    x:Class="SnapDoc.Controls.Switch"
    x:Name="this">

    <Grid ColumnDefinitions="Auto, Auto" 
          ColumnSpacing="16"
          VerticalOptions="Center"
          HorizontalOptions="Start"
          x:DataType="controls:Switch"
          GestureRecognizers="{TapGestureRecognizer Tapped=OnTapped}">

        <Grid Grid.Column="0"
              HeightRequest="{Binding SwitchHeight, Source={x:Reference this}}"
              WidthRequest="{Binding SwitchWidth, Source={x:Reference this}}">

            <Border x:Name="OuterContainer"
                    BackgroundColor="{Binding CurrentSwitchColor, Source={x:Reference this}}"/>

            <Border x:Name="Knob"
                    BackgroundColor="{Binding CurrentKnobColor, Source={x:Reference this}}"
                    HorizontalOptions="Start"
                    VerticalOptions="Center"
                    WidthRequest="{Binding KnobSize, Source={x:Reference this}}"
                    HeightRequest="{Binding KnobSize, Source={x:Reference this}}"/>

            <Path x:Name="CustomPath"
                  StrokeThickness="0.5"/>
        </Grid>

        <Label Grid.Column="1"
               Text="{Binding LabelText, Source={x:Reference this}}"
               TextColor="{Binding TextColor, Source={x:Reference this}}"
               FontSize="{Binding TextSize, Source={x:Reference this}}"
               VerticalTextAlignment="Center" />
    </Grid>
</ContentView>