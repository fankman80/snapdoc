<?xml version="1.0" encoding="UTF-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/maui/global"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:uranium="http://schemas.enisn-projects.io/dotnet/maui/uraniumui"
             xmlns:views="clr-namespace:SnapDoc.Views"
             xmlns:res="clr-namespace:SnapDoc.Resources.Languages"
             xmlns:local="clr-namespace:SnapDoc"
             BackgroundColor="DimGrey"
             x:DataType="views:LoadPDFPages"
             Shell.TitleColor="{DynamicResource PrimaryDark}"
             Shell.BackgroundColor="{DynamicResource SecondaryBackgroundDark}"
             x:Class="SnapDoc.Views.LoadPDFPages"
             x:Name="ThisPage"
             Title="PDF Seiten hinzufügen">

    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsVisible="False" />
    </Shell.BackButtonBehavior>

    <Shell.TitleView>
        <Grid ColumnDefinitions="Auto,*,Auto"
              ColumnSpacing="0"
              VerticalOptions="Center">

            <Button Grid.Column="0"
                    Text="{x:Static local:MaterialIcons.Arrow_back}"
                    FontFamily="MaterialOutlined"
                    FontSize="24"
                    Padding="12,0"
                    TextColor="{DynamicResource PrimaryDark}"
                    Background="Transparent"
                    BackgroundColor="Transparent"
                    VerticalOptions="Center"
                    Clicked="OnCancelClicked"/>
            <Label Grid.Column="1"
                   Text="{Binding Title, Source={x:Reference Name=ThisPage}}"
                   TextColor="{DynamicResource PrimaryDark}"
                   Background="Transparent"
                   BackgroundColor="Transparent"
                   FontSize="18"
                   VerticalOptions="Center"
                   HorizontalOptions="Start"/>

            <Button Grid.Column="2"
                    x:Name="btnRows"
                    FontSize="24"
                    Padding="10,0"
                    TextColor="{DynamicResource PrimaryDark}"
                    Background="Transparent"
                    FontFamily="MaterialOutlined"
                    VerticalOptions="Center"
                    HorizontalOptions="End"
                    ToolTipProperties.Text="{x:Static res:AppResources.raster_liste_umschalten}"                    
                    Clicked="OnChangeRowsClicked"/>
        </Grid>
    </Shell.TitleView>

    <Grid>
        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <CollectionView x:Name="fileListView"
                            Grid.Row="0"
                            ItemSizingStrategy="MeasureAllItems"
                            ItemsUpdatingScrollMode="KeepItemsInView">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical"
                                     Span="{Binding DynamicSpan}" 
                                     HorizontalItemSpacing="4"
                                     VerticalItemSpacing="4"/>
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="local:PdfItem">
                        <Grid MinimumHeightRequest="140"
                              BackgroundColor="Gray">
                            <Image Source="{Binding PreviewPath}"
                                   Aspect="AspectFit"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   HeightRequest="180"/>
                            <CheckBox IsChecked="{Binding IsChecked}"
                                      Color="{DynamicResource Primary}"
                                      VerticalOptions="End"
                                      HorizontalOptions="End"
                                      ZIndex="2"/>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Grid Grid.Row="1" Margin="0,6,16,16" ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="1"
                        Text="{x:Static res:AppResources.abbrechen}"
                        BackgroundColor="{AppThemeBinding Light={DynamicResource Primary}, Dark={DynamicResource PrimaryDark}}"
                        TextColor="{DynamicResource PrimaryDarkText}"
                        Clicked="OnCancelClicked"/>
                <Button Grid.Column="2"
                        Text="{x:Static res:AppResources.seiten_hinzufuegen}"
                        BackgroundColor="{AppThemeBinding Light={DynamicResource Primary}, Dark={DynamicResource PrimaryDark}}"
                        TextColor="{DynamicResource PrimaryDarkText}"
                        Clicked="OnPagesAddClicked"/>
            </Grid>
        </Grid>

        <local:BusyOverlayView x:Name="busyOverlay"
                               IsVisible="False"
                               InputTransparent="True"
                               AbsoluteLayout.LayoutBounds="0,0,1,1"
                               AbsoluteLayout.LayoutFlags="All"/>
    </Grid>
</ContentPage>