<?xml version="1.0" encoding="UTF-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/maui/global"
			 xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
			 xmlns:mr="clr-namespace:MR.Gestures;assembly=MR.Gestures"		 
             xmlns:pc="clr-namespace:SnapDoc.ViewModels"
             xmlns:views="clr-namespace:SnapDoc.Views" 
             xmlns:services="clr-namespace:SnapDoc.Services"
             xmlns:res="clr-namespace:SnapDoc.Resources.Languages"
             xmlns:local="clr-namespace:SnapDoc"
			 BackgroundColor="DimGrey"
             Shell.TitleColor="{DynamicResource PrimaryDark}"
             Shell.BackgroundColor="{DynamicResource SecondaryBackgroundDark}"
			 x:Class="SnapDoc.Views.ImageViewPage"
             x:Name="ThisPage">

    <Shell.TitleView>
        <Grid ColumnDefinitions="*,Auto,Auto,Auto"
              x:DataType="views:ImageViewPage"
              ColumnSpacing="0"
              VerticalOptions="Center">
            <Label Grid.Column="0"
                   Text="{Binding Title, Source={x:Reference Name=ThisPage}}"
                   TextColor="{DynamicResource PrimaryDark}"
                   Background="Transparent"
                   BackgroundColor="Transparent"
                   FontSize="18"
                   VerticalOptions="Center"
                   HorizontalOptions="Start"/>
            <Button Grid.Column="1"
                    IsVisible="{Binding IsGotoPinBtnVisible}"
                    Text="{x:Static local:MaterialIcons.Pinboard}"
                    FontSize="24"
                    Padding="0"
                    TextColor="{DynamicResource PrimaryDark}"
                    Background="Transparent"
                    FontFamily="MaterialOutlined"
                    VerticalOptions="Center"
                    HorizontalOptions="End"
                    ToolTipProperties.Text="{x:Static res:AppResources.zu_pin_wechseln}"
                    Clicked="OnEditClicked"/>
            <Button Grid.Column="2"
                    Text="{x:Static local:MaterialIcons.Fit_screen}"
                    FontSize="24"
                    Padding="0"
                    TextColor="{DynamicResource PrimaryDark}"
                    Background="Transparent"
                    FontFamily="MaterialOutlined"
                    VerticalOptions="Center"
                    HorizontalOptions="End"
                    ToolTipProperties.Text="{x:Static res:AppResources.foto_auf_fenstergroesse_zoomen}"
                    Clicked="ImageFit"/>
            <Button Grid.Column="3"
                    Text="{x:Static local:MaterialIcons.Delete}"
                    FontSize="24"
                    Padding="0"
                    TextColor="{DynamicResource PrimaryDark}"
                    Background="Transparent"
                    FontFamily="MaterialOutlined"
                    VerticalOptions="Center"
                    HorizontalOptions="End"
                    ToolTipProperties.Text="{x:Static res:AppResources.foto_loeschen}"
                    Clicked="OnDeleteButtonClicked"/>
        </Grid>
    </Shell.TitleView>

    <Grid>
        <mr:AbsoluteLayout x:Name="GestureContainer"
                           x:DataType="pc:TransformViewModel"
                           IsClippedToBounds="True"
                           PinchingCommand="{Binding PinchingCommand}"
                           Panning="OnPanning"
                           Pinching="OnPinching"
                           Pinched="OnPinched"
                           DoubleTapped="OnDoubleTapped"
                           ScrollWheelChanged="OnMouseScroll">
            <Grid x:Name="ImageDrawingCanvas"
                  AbsoluteLayout.LayoutBounds="0, 0, -1, -1"
                  AbsoluteLayout.LayoutFlags="None"
                  Scale="{Binding Scale}"
                  TranslationX="{Binding TranslationX}"
                  TranslationY="{Binding TranslationY}"
                  AnchorX="{Binding AnchorX}"
                  AnchorY="{Binding AnchorY}">

                <Image x:Name="FotoContainer"
                       InputTransparent="True" />
            </Grid>
        </mr:AbsoluteLayout>

        <Button x:Name="DrawBtn"
                Text="{x:Static local:MaterialIcons.Draw}"
                Margin="20,0,0,20"
                ZIndex="10000"
                VerticalOptions="End"
                HorizontalOptions="Start"
                Style="{StaticResource ToolButtonStyle}"
                ToolTipProperties.Text="{x:Static res:AppResources.formen_zeichnen}"
                Clicked="DrawingClicked"/>

        <VerticalStackLayout x:DataType="views:ImageViewPage"
                             IsVisible="{Binding IsToolButtonsVisible}"
                             Spacing="16"
                             Margin="20"
                             HorizontalOptions="Start"
                             VerticalOptions="End"
                             ZIndex="10000">
            <Button Text="{x:Static local:MaterialIcons.Ink_eraser}" 
                    Style="{StaticResource ToolButtonStyle}"
                    ToolTipProperties.Text="{x:Static res:AppResources.zeichnung_loeschen}"
                    Clicked="EraseClicked"/>
            <AbsoluteLayout>
                <Button Text="{x:Static local:MaterialIcons.Palette}"
                        Style="{StaticResource ToolButtonStyle}"
                        ToolTipProperties.Text="{x:Static res:AppResources.farbe_und_stiftbreite_waehlen}"
                        Clicked="PenSettingsClicked"/>
                <Border WidthRequest="20"
                        HeightRequest="20"
                        BackgroundColor="{Binding Source={x:Reference Name=ThisPage}, Path=SelectedBorderColor, Converter={StaticResource ColorWithoutAlphaConverter}}"                              
                        StrokeThickness="0"
                        AbsoluteLayout.LayoutBounds="0, 0, AutoSize, AutoSize"
                        AbsoluteLayout.LayoutFlags="PositionProportional">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="11"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" 
                                Opacity="0.3" 
                                Offset="3,3" 
                                Radius="3"/>
                    </Border.Shadow>
                </Border>
                <Border WidthRequest="20"
                        HeightRequest="20"
                        BackgroundColor="{Binding Source={x:Reference Name=ThisPage}, Path=SelectedFillColor, Converter={StaticResource ColorWithoutAlphaConverter}}"                              
                        StrokeThickness="0"
                        AbsoluteLayout.LayoutBounds="0, 1, AutoSize, AutoSize"
                        AbsoluteLayout.LayoutFlags="PositionProportional">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="11"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" 
                                Opacity="0.3" 
                                Offset="3,3" 
                                Radius="3"/>
                    </Border.Shadow>
                </Border>
            </AbsoluteLayout>
            <Button x:Name="AddTextBtn"
                    IsVisible="False"
                    Text="{x:Static local:MaterialIcons.Text_fields}"
                    Style="{StaticResource ToolButtonStyle}"
                    ToolTipProperties.Text="{x:Static res:AppResources.textfeld_bearbeiten}"
                    Clicked="TextClicked"/>
            <Button x:Name="AddCloudyBtn"
                    IsVisible="False"
                    Text="{x:Static local:MaterialIcons.Cloud_off}" 
                    Style="{StaticResource ToolButtonStyle}"
                    ToolTipProperties.Text="{x:Static res:AppResources.textfeld_bearbeiten}"
                    Clicked="CloudyClicked"/>
            <Button x:Name="ShapeBtn"
                    Text="{x:Static local:MaterialIcons.Activity_zone}"                  
                    Style="{StaticResource ToolButtonStyle}"
                    ToolTipProperties.Text="{x:Static res:AppResources.form_waehlen}"
                    Clicked="ShapeButtonClicked"/>
            <Button Text="{x:Static local:MaterialIcons.Check}"  
                    BackgroundColor="LimeGreen"
                    Style="{StaticResource ToolButtonStyle}"
                    ToolTipProperties.Text="{x:Static res:AppResources.zeichnung_speichern}"
                    Clicked="CheckClicked"/>
        </VerticalStackLayout>
    </Grid>
</ContentPage>
