<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:cv="clr-namespace:Camera.MAUI;assembly=Camera.MAUI"
             xmlns:res="clr-namespace:SnapDoc.Resources.Languages"
             xmlns:local="clr-namespace:SnapDoc"             
             x:Class="SnapDoc.Views.CameraView"
             Shell.NavBarIsVisible="False">

    <Grid HorizontalOptions="Fill" VerticalOptions="Fill">
        <cv:CameraView x:Name="cameraView"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       ZIndex="0"/>

        <Image x:Name="previewImage" 
               IsVisible="False" 
               BackgroundColor="Black" 
               Aspect="AspectFit" 
               ZIndex="1"/>

        <AbsoluteLayout VerticalOptions="Start" Padding="20" ZIndex="2">
            <Button HeightRequest="40" WidthRequest="40" CornerRadius="20"
                        Text="{x:Static local:MaterialIcons.Close}"
                        Padding="0"
                        FontSize="26"
                        FontFamily="MaterialOutlined"
                        TextColor="White"
                        BackgroundColor="#404040"
                        Opacity="0.6"
                        Clicked="OnCloseClicked"/>
        </AbsoluteLayout>

        <VerticalStackLayout VerticalOptions="End" Padding="30" ZIndex="2">
            <HorizontalStackLayout x:Name="liveButtons" HorizontalOptions="Center" Spacing="50">
                <Button HeightRequest="60" WidthRequest="60" CornerRadius="30"
                        Text="{x:Static local:MaterialIcons.Flash_auto}"
                        Padding="0"
                        FontSize="36"
                        FontFamily="MaterialOutlined"
                        TextColor="White"
                        BackgroundColor="#404040"
                        Opacity="0.6"                   
                        Clicked="OnFlashButtonClicked"/>
                <Button x:Name="controlButton"
                        HeightRequest="80" WidthRequest="80" CornerRadius="40"
                        Text="{x:Static local:MaterialIcons.Photo_camera}"
                        Padding="0"
                        FontSize="46"
                        FontFamily="MaterialOutlined"
                        BackgroundColor="{AppThemeBinding Light={DynamicResource Primary}, Dark={DynamicResource PrimaryDark}}"                      
                        Clicked="OnCaptureClicked"/>
                <Button HeightRequest="60" WidthRequest="60" CornerRadius="30"
                        Text="{x:Static local:MaterialIcons.Flip_camera_ios}"
                        Padding="0"
                        FontSize="36"
                        FontFamily="MaterialOutlined"
                        TextColor="White"
                        BackgroundColor="#404040"
                        Opacity="0.6"                     
                        Clicked="OnSwitchCameraClicked"/>
            </HorizontalStackLayout>

            <HorizontalStackLayout x:Name="previewButtons" IsVisible="False" HorizontalOptions="Center" Spacing="50">
                <Button Text="{x:Static res:AppResources.abbrechen}" Clicked="OnRetakeClicked" BackgroundColor="Red"/>
                <Button Text="{x:Static res:AppResources.speichern}" Clicked="OnConfirmClicked" BackgroundColor="Green"/>
            </HorizontalStackLayout>

        </VerticalStackLayout>
        <BoxView x:Name="flashOverlay"
                 BackgroundColor="White"
                 Opacity="0"
                 IsVisible="False"
                 InputTransparent="True" 
                 HorizontalOptions="Fill"
                 VerticalOptions="Fill"
                 ZIndex="99" />
    </Grid>
</ContentPage>