<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="SnapDoc.Views.CameraView"
             Title="Kamera">

    <Grid ColumnDefinitions="*,*,*" RowDefinitions="*,Auto,Auto">
        <toolkit:CameraView
        x:Name="MainCamera" 
        Grid.ColumnSpan="3" 
        Grid.Row="0" />

        <Slider 
        x:Name="ZoomSlider"
        Grid.Column="0"
        Grid.Row="1" />

        <Picker 
        x:Name="FlashPicker"
        ItemDisplayBinding="{Binding .}"
        Grid.Column="1"
        Grid.Row="1"
        Title="Flash" />

        <Picker 
        x:Name="ResolutionPicker"
        Grid.Column="2"
        Grid.Row="1"
        Title="Resolutions" />

        <Button
        x:Name="CaptureButton"
        Grid.Column="0"
        Grid.Row="2"
        Text="Capture Image" />

        <Button
        x:Name="SwitchCameraButton"
        Grid.Column="1"
        Grid.Row="2"
        Text="Kamera wechseln"
        Clicked="OnSwitchCameraClicked" />
    </Grid>
</ContentPage>