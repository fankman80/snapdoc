<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/maui/global"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               xmlns:uranium="http://schemas.enisn-projects.io/dotnet/maui/uraniumui"
               xmlns:material="http://schemas.enisn-projects.io/dotnet/maui/uraniumui/material"
               xmlns:controls="clr-namespace:SnapDoc.Controls"
               xmlns:views="clr-namespace:SnapDoc.Views"
               xmlns:res="clr-namespace:SnapDoc.Resources.Languages"
               xmlns:local="clr-namespace:SnapDoc"              
               BackgroundColor="{AppThemeBinding Light={DynamicResource PrimaryBackground}, Dark={DynamicResource PrimaryBackgroundDark}}"
               HorizontalOptions="Center"
               x:TypeArguments="x:Object"
               CanBeDismissedByTappingOutsideOfPopup="True"
               x:Class="SnapDoc.Views.PopupShapeSelect">

    <Grid Padding="12">
        <Grid ColumnDefinitions="Auto,Auto"
              RowDefinitions="Auto,Auto,Auto"
              ColumnSpacing="14"
              RowSpacing="14">
            <Label Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="2" Text="{x:Static res:AppResources.form_waehlen}"/>
            <Button Grid.Column="0" Grid.Row="1"
                    Rotation="90"
                    Text="{x:Static local:MaterialIcons.Activity_zone}"
                    FontSize="34"
                    FontFamily="MaterialOutlined"
                    CornerRadius="8"
                    Style="{StaticResource ToolButtonStyle}"
                    Clicked="RectBtnClicked"
                    ToolTipProperties.Text="{x:Static res:AppResources.rechteck_zeichnen}"/>

            <Button Grid.Column="1" Grid.Row="1"
                    Rotation="90"
                    Text="{x:Static local:MaterialIcons.Polyline}"
                    FontSize="34"
                    FontFamily="MaterialOutlined"
                    CornerRadius="8"
                    Style="{StaticResource ToolButtonStyle}"
                    Clicked="PolyBtnClicked"
                    ToolTipProperties.Text="{x:Static res:AppResources.polylinie_zeichnen}"/>

            <Button Grid.Column="0" Grid.Row="2"
                    Rotation="90"
                    Text="{x:Static local:MaterialIcons.Arrow_shape_up}"
                    FontSize="34"
                    FontFamily="MaterialOutlined"
                    CornerRadius="8"
                    Style="{StaticResource ToolButtonStyle}"
                    Clicked="ArrowBtnClicked"
                    ToolTipProperties.Text="{x:Static res:AppResources.pfeil_zeichnen}"/>

            <Button Grid.Column="1" Grid.Row="2"
                    Rotation="90"
                    Text="{x:Static local:MaterialIcons.Gesture}"
                    FontSize="34"
                    FontFamily="MaterialOutlined"
                    CornerRadius="8"
                    Style="{StaticResource ToolButtonStyle}"
                    Clicked="FreeBtnClicked"
                    ToolTipProperties.Text="{x:Static res:AppResources.freihandlinie_zeichnen}"/>
        </Grid>
    </Grid>
</toolkit:Popup>
